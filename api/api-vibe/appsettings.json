{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppVersion": "1.0.0",
  "HealthCheck": {
    "DependencyTimeoutMs": 500,
    "ExcludeAuthRoutes": [ "/health", "/health/ready" ]
  },
  "Gemini": {
    "ApiKey": "YOUR_API_KEY_DONT_USE_MY",
    "Endpoint": "https://generativelanguage.googleapis.com",
    "Model": "gemini-flash-latest"
  },
  "GasPrice": {
    "CacheDurationMinutes": 60
  }
}
